# ========================
# .gitignore
# ========================
# This file tells Git which files/folders to NEVER track.


# ── Node / React ──────────────────────────────────────────
node_modules/          # npm packages — huge, always regeneratable
dist/                  # Built output — generated, not source
build/                 # Alternative build output folder
.env                   # Environment variables — NEVER commit secrets
.env.local
.env.production

# ── .NET / C# ─────────────────────────────────────────────
backend/*/bin/         # Compiled binaries — generated by dotnet build
backend/*/obj/         # Intermediate build files — generated
*.user                 # VS Code user-specific settings
*.suo                  # Visual Studio solution user options

# ── Docker ────────────────────────────────────────────────
# (docker-compose.yml IS committed — it's config, not a secret)

# ── OS Files ──────────────────────────────────────────────
.DS_Store              # Mac metadata files
Thumbs.db              # Windows thumbnail cache